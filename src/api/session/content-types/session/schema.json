{
  "kind": "collectionType",
  "collectionName": "sessions",
  "info": {
    "singularName": "session",
    "pluralName": "sessions",
    "displayName": "Session"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "sessionId": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "email": {
      "type": "email"
    },
    "playerId": {
      "type": "string"
    },
    "lastActiveAt": {
      "type": "datetime"
    },
    "lastNotifiedAt": {
      "type": "datetime"
    },
    "isActive": {
      "type": "boolean",
      "default": true
    },
    "wishlist": {
      "type": "component",
      "repeatable": false,
      "component": "wishlist-item.wishlist"
    }
  }
}
